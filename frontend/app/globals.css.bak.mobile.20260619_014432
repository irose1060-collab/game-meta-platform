  align-items: center;
  margin-bottom: 18px;
}

.notice-detail-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
  padding-bottom: 18px;
  margin-bottom: 24px;
  border-bottom: 1px solid var(--line);
  color: var(--text-dim);
  font-size: 13px;
}

.notice-detail-content {
  white-space: pre-wrap;
  color: #c5cbd9;
  line-height: 1.9;
  font-size: 15px;
  min-height: 180px;
}

.notice-detail-actions {
  display: flex;
  justify-content: flex-end;
  gap: 10px;
  margin-top: 32px;
}

.notice-detail-empty {
  text-align: center;
  color: var(--text-dim);
  padding: 60px 20px;
}

.notice-detail-empty h2 {
  color: var(--gold-2);
}

/* =========================================================
   Admin page
   ========================================================= */
.admin-page {
  min-height: 100vh;
  padding: 32px 0 80px;
  background:
    radial-gradient(900px 500px at 80% -10%, rgba(10, 200, 185, 0.12), transparent 60%),
    radial-gradient(700px 400px at 10% 10%, rgba(200, 155, 60, 0.12), transparent 60%),
    linear-gradient(180deg, #05070c 0%, #0a1020 70%, #06080d 100%);
  color: var(--text);
}

.admin-header {
  max-width: 1240px;
  margin: 0 auto;
  padding: 0 24px 36px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.admin-header-actions {
  display: flex;
  gap: 10px;
}

.admin-hero {
  max-width: 1240px;
  margin: 0 auto;
  padding: 40px 24px 32px;
}

.admin-hero h1 {
  font-family: "Cinzel", serif;
  font-size: clamp(42px, 6vw, 72px);
  color: var(--gold-2);
  letter-spacing: 4px;
  margin-top: 16px;
}

.admin-hero p {
  margin-top: 16px;
  color: #c5cbd9;
  max-width: 780px;
}

.admin-layout {
  max-width: 1240px;
  margin: 0 auto;
  padding: 24px;
  display: grid;
  grid-template-columns: 240px 1fr;
  gap: 18px;
}

.admin-sidebar {
  background: var(--card);
  border: 1px solid var(--line);
  border-radius: var(--radius);
  padding: 16px;
  height: fit-content;
  box-shadow: var(--shadow);
}

.admin-sidebar button {
  width: 100%;
  text-align: left;
  padding: 13px 14px;
  border-radius: 8px;
  color: var(--text-dim);
  transition: all 0.2s ease;
  margin-bottom: 8px;
}

.admin-sidebar button:hover,
.admin-sidebar button.active {
  color: var(--gold-2);
  background: rgba(200, 155, 60, 0.12);
}

.admin-content {
  min-width: 0;
}

.admin-section {
  background: var(--card);
  border: 1px solid var(--line);
  border-radius: var(--radius);
  padding: 28px;
  box-shadow: var(--shadow);
}

.admin-section h2 {
  color: var(--gold-2);
  margin: 8px 0 8px;
}

.admin-section p {
  color: #c5cbd9;
  font-size: 14px;
}

.admin-form {
  margin-top: 24px;
  padding: 20px;
  border: 1px solid var(--line);
  border-radius: 12px;
  background: rgba(0, 0, 0, 0.18);
}

.admin-form h3,
.admin-table-wrap h3,
.admin-log-box h3 {
  color: var(--gold-2);
  margin-bottom: 14px;
}

.admin-form label {
  display: block;
  color: var(--text-dim);
  font-size: 12px;
  margin: 12px 0 6px;
}

.admin-form input,
.admin-form textarea {
  width: 100%;
  padding: 12px 14px;
  border-radius: 8px;
  background: rgba(0, 0, 0, 0.3);
  border: 1px solid var(--line);
  color: #fff;
  font-family: inherit;
}

.admin-form textarea {
  min-height: 120px;
  resize: vertical;
}

.admin-checkbox {
  display: flex !important;
  align-items: center;
  gap: 8px;
}

.admin-checkbox input {
  width: auto;
}

.admin-form-actions {
  display: flex;
  gap: 10px;
  margin-top: 16px;
}

.admin-table-wrap {
  margin-top: 28px;
}

.admin-table {
  margin-top: 16px;
  border: 1px solid var(--line);
  border-radius: 10px;
  overflow: hidden;
}

.admin-row {
  display: grid;
  grid-template-columns: 1.5fr 0.8fr 0.7fr 0.7fr 1.4fr;
  gap: 12px;
  padding: 12px 14px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  font-size: 13px;
  color: #c5cbd9;
  align-items: stretch;
}

.admin-row-notice {
  grid-template-columns: 1.6fr 0.8fr 0.8fr 1fr;
}

.admin-row:last-child {
  border-bottom: none;
}

.admin-row-head {
  background: rgba(200, 155, 60, 0.1);
  color: var(--gold-2);
  font-weight: 700;
}

.admin-row-actions {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

.admin-row-actions button {
  padding: 6px 10px;
  border-radius: 6px;
  border: 1px solid var(--line);
  color: var(--gold-2);
  font-size: 12px;
  white-space: nowrap;
}

.admin-row-actions-vertical {
  display: flex;
  flex-direction: column;
  gap: 8px;
  align-items: flex-end;
  justify-content: space-between;
}

.admin-action-top,
.admin-action-middle,
.admin-action-bottom {
  display: flex;
  justify-content: flex-end;
  gap: 8px;
  width: 100%;
}

.admin-action-bottom {
  margin-top: 4px;
}

.role-change-button {
  border-color: rgba(10, 200, 185, 0.55) !important;
  color: var(--teal-2) !important;
  background: rgba(10, 200, 185, 0.08) !important;
}

.role-change-button:hover {
  background: rgba(10, 200, 185, 0.18) !important;
  border-color: var(--teal) !important;
}

.admin-row-actions button:last-child {
  border-color: rgba(255, 93, 108, 0.5);
  color: #ff8a96;
}

.admin-row-actions button:last-child:hover {
  background: rgba(255, 93, 108, 0.12);
}

.status-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14px;
  margin-top: 24px;
}

.status-box {
  padding: 18px;
  border: 1px solid rgba(10, 200, 185, 0.35);
  border-radius: 12px;
  background: rgba(10, 200, 185, 0.06);
}

.status-box strong {
  display: block;
  color: var(--teal-2);
  margin-bottom: 8px;
}

.status-box span {
  color: #c5cbd9;
  font-size: 14px;
}

.admin-log-box {
  margin: 24px 0;
  padding: 20px;
  border: 1px solid var(--line);
  border-radius: 12px;
  background: rgba(0, 0, 0, 0.2);
}

.admin-panel {
  max-width: 520px;
  margin: 160px auto 0;
  padding: 36px;
  border: 1px solid var(--line);
  border-radius: var(--radius);
  background: var(--card);
  text-align: center;
  box-shadow: var(--shadow);
}

.admin-panel h1 {
  color: var(--gold-2);
  margin-bottom: 14px;
}

.admin-panel p {
  color: #c5cbd9;
  margin-bottom: 24px;
}

@media (max-width: 980px){
  .cards{grid-template-columns:repeat(2,1fr)}
  .menu{display:none}
  .auth .btn-ghost{display:none}
  .hamburger{display:block}
}

@media (max-width: 900px) {
  .admin-layout {
    grid-template-columns: 1fr;
  }

  .status-grid {
    grid-template-columns: 1fr;
  }

  .admin-row,
  .admin-row-notice {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 760px) {
  .notice-board-card {
    flex-direction: column;
    align-items: flex-start;
  }

  .notice-board-card-right {
    align-items: flex-start;
  }
}

@media (max-width: 600px){
  .hero{padding:60px 0 30px}
  .search-wrap{flex-direction:column;padding:12px}
  .search-wrap input,.search-btn{width:100%}
  .tag-input{border-left:none !important;border-top:1px solid rgba(255,255,255,0.06) !important;max-width:none}
  .cards{grid-template-columns:1fr}
  .section-head{flex-direction:column;align-items:flex-start;gap:8px}
  .section-head .line{display:none}
  .notice-item{flex-direction:column;align-items:flex-start;gap:6px}
  .notice-date{margin-left:0}
}

/* =========================
   META GG Header
========================= */

.header {
  position: sticky;
  top: 0;
  z-index: 50;
  width: 100%;
  border-bottom: 1px solid rgba(245, 197, 66, 0.16);
  background: rgba(7, 10, 18, 0.92);
  backdrop-filter: blur(14px);
}

.container {
  width: min(1280px, calc(100% - 48px));
  margin: 0 auto;
}

.header-content {
  height: 72px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 28px;
}

.logo {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  color: #f5c542;
  font-size: 28px;
  font-weight: 950;
  letter-spacing: 0.08em;
  text-decoration: none;
  white-space: nowrap;
  font-family: Georgia, "Times New Roman", serif;
}

.logo-mark {
  font-size: 19px;
  color: #d6a73c;
}

.main-nav {
  flex: 1;
  display: flex;
  justify-content: center;
}

.main-nav ul {
  display: flex;
  align-items: center;
  gap: 8px;
  margin: 0;
  padding: 0;
  list-style: none;
}

.main-nav li {
  margin: 0;
  padding: 0;
}

.main-nav a,
.main-nav button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 40px;
  padding: 0 14px;
  border: 1px solid transparent;
  border-radius: 999px;
  background: transparent;
  color: #d6d9e2;
  font-size: 15px;
  font-weight: 800;
  text-decoration: none;
  cursor: pointer;
  transition: 0.16s ease;
}

.main-nav a:hover,
.main-nav button:hover {
  border-color: rgba(245, 197, 66, 0.36);
  background: rgba(245, 197, 66, 0.08);
  color: #f5c542;
}

.auth-section {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 10px;
  min-width: 190px;
}

.user-nickname {
  color: #f8fafc;
  font-size: 14px;
  font-weight: 800;
  white-space: nowrap;
}

.button-secondary,
.button-primary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 38px;
  padding: 0 14px;
  border-radius: 999px;
  font-size: 14px;
  font-weight: 900;
  text-decoration: none;
  cursor: pointer;
  transition: 0.16s ease;
  white-space: nowrap;
}

.button-secondary {
  border: 1px solid rgba(245, 197, 66, 0.28);
  background: rgba(255, 255, 255, 0.035);
  color: #e5e7eb;
}

.button-secondary:hover {
  border-color: rgba(245, 197, 66, 0.55);
  color: #f5c542;
}

.button-primary {
  border: 1px solid rgba(245, 197, 66, 0.65);
  background: linear-gradient(135deg, #f5c542, #b88924);
  color: #111827;
}

.button-primary:hover {
  filter: brightness(1.08);
}

.admin-button {
  color: #f5c542;
}

@media (max-width: 900px) {
  .header-content {
    height: auto;
    min-height: 72px;
    padding: 16px 0;
    flex-wrap: wrap;
  }

  .main-nav {
    order: 3;
    width: 100%;
    justify-content: flex-start;
    overflow-x: auto;
  }

  .main-nav ul {
    flex-wrap: nowrap;
  }

  .auth-section {
    min-width: auto;
  }
}